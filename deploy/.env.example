COMPOSE_PROJECT_NAME=mall
MALL_DEPLOY_ROOT=/opt/mall-deploy

# Replace this with the real public IP when generating user-facing links.
SERVER_PUBLIC_HOST=192.168.28.211

# Image overrides are useful when Docker Hub is slow or blocked.
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.4
NACOS_IMAGE=nacos/nacos-server:v2.4.3
ROCKETMQ_IMAGE=apache/rocketmq:5.3.2
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.19.4
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
XXL_JOB_IMAGE=xuxueli/xxl-job-admin:2.4.1

MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_APP_DATABASE=mall
MYSQL_APP_USER=mall
MYSQL_APP_PASSWORD=change-app-password
NACOS_DATABASE=nacos_config
XXL_JOB_DATABASE=xxl_job

REDIS_PASSWORD=change-redis-password

MALL_TOKEN_SECRET=change-token-secret-at-least-32-chars

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-minio-password

MALL_BASIC_AUTH_USER=mallops
MALL_BASIC_AUTH_PASSWORD=change-basic-auth-password

TZ=Asia/Shanghai
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseContainerSupport
GATEWAY_JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseContainerSupport
